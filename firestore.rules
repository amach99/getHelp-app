rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: read anyone, write only own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Tickets: anyone logged in can read open tickets
    // Only requester can create/delete; helpers can update acceptedHelpers
    match /tickets/{ticketId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.requesterId == request.auth.uid;
      allow update: if request.auth != null && (
        // Requester can update anything
        resource.data.requesterId == request.auth.uid
        // Helpers can only add themselves to acceptedHelpers
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acceptedHelpers', 'status'])
            && request.auth.uid in request.resource.data.acceptedHelpers)
      );
      allow delete: if request.auth != null
        && resource.data.requesterId == request.auth.uid;

      // Messages subcollection: only ticket participants can read/write
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/tickets/$(ticketId)).data.requesterId == request.auth.uid
          || request.auth.uid in get(/databases/$(database)/documents/tickets/$(ticketId)).data.acceptedHelpers
        );
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && (
            get(/databases/$(database)/documents/tickets/$(ticketId)).data.requesterId == request.auth.uid
            || request.auth.uid in get(/databases/$(database)/documents/tickets/$(ticketId)).data.acceptedHelpers
          );
      }
    }
  }
}
